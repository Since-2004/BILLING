{
  "name": "billing",
  "version": "0.1.6",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "npm rebuild better-sqlite3 && next dev",
    "build": "prisma generate && next build && node package.js",
    "start": "next start",
    "lint": "next lint",
    "electron": "npx @electron/rebuild -v 42.4.1 -f -w better-sqlite3 && electron .",
    "dist": "npm run build && npx @electron/rebuild -v 42.4.1 -f -w better-sqlite3 && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "pg-boss": "^12.19.1",
    "prisma": "^7.8.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.billing.erp",
    "npmRebuild": false,
    "productName": "Nucleus",
    "directories": {
      "output": "dist"
    },
    "executableName": "Nucleus",
    "files": [
      "main.js",
      "dev.db",
      "package.json",
      ".env",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*",
      {
        "from": ".next/standalone",
        "to": ".next/standalone"
      }
    ],
    "asar": true,
    "extraFiles": [
      ".env",
      {
        "from": "node_modules/.prisma",
        "to": "resources/app.asar.unpacked/node_modules/.prisma"
      },
      {
        "from": "node_modules/.prisma",
        "to": "resources/app.asar.unpacked/.next/standalone/node_modules/.prisma"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/.prisma/**/*",
      "**/node_modules/@prisma/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
